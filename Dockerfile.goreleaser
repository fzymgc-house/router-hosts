# Dockerfile used by GoReleaser dockers_v2 — copies pre-built binaries.
# dockers_v2 places binaries under linux/{TARGETARCH}/ in the build context.
# For local builds, use `docker build -f Dockerfile .` instead.
FROM gcr.io/distroless/static:nonroot
ARG TARGETARCH

COPY linux/${TARGETARCH}/router-hosts /usr/local/bin/router-hosts
COPY linux/${TARGETARCH}/operator /usr/local/bin/operator

EXPOSE 50051

ENTRYPOINT ["router-hosts"]
CMD ["serve", "--config", "/etc/router-hosts/server.toml"]
